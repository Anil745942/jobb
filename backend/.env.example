# ╔══════════════════════════════════════════════════════════════╗
# ║          JobConnect Pro - Environment Variables             ║
# ║          Copy this to .env and fill in your values          ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── Server ───────────────────────────────────────────────────
PORT=10000
NODE_ENV=production

# ─── Database (Render PostgreSQL) ─────────────────────────────
# Render se Postgres banane ke baad "External Database URL" yahan paste karo
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME"

# ─── Authentication ───────────────────────────────────────────
JWT_SECRET="yahan-koi-bhi-random-secure-string-daal-do-jo-lamba-ho"

# ─── File Uploads ─────────────────────────────────────────────
UPLOAD_DIR="./uploads"

# ─── Frontend URL (CORS ke liye) ─────────────────────────────
FRONTEND_URL="https://jobconnect-frontend.onrender.com"
